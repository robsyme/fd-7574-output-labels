manifest {
    name        = 'fd-7574-output-labels'
    author      = 'Rob Syme'
    description = 'Minimal test of workflow output labels surfacing in Platform data lineage (FD-7574)'
    mainScript  = 'main.nf'
}

// Tasks run in containers on Platform compute environments.
process.container = 'quay.io/nextflow/bash'

// NOTE: lineage is intentionally NOT configured here.
// On Seqera Platform (staging) data lineage is enabled at the workspace level,
// which injects lineage.enabled and lineage.store.location (the S3 store).
// Setting them here would override the workspace store. For a local run, pass:
//   -c local.config
// or enable lineage on the command line.
